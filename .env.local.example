# Google OAuth 2.0 Configuration
# To enable Google Login, you need to:
# 1. Go to Google Cloud Console (https://console.cloud.google.com/)
# 2. Create a new project or use existing one
# 3. Enable Google Identity Services API
# 4. Go to "Credentials" and create an OAuth 2.0 Client ID for Web Application
# 5. Add authorized origins: http://localhost:5173 and http://localhost:5174
# 6. Add authorized redirect URIs: http://localhost:5173 and http://localhost:5174
# 7. Copy the Client ID and paste it below as VITE_GOOGLE_CLIENT_ID

VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Backend API Configuration
VITE_API_URL=http://localhost:5000
